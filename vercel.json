{
  "framework": "nextjs",
"buildCommand": "prisma generate && prisma db push --accept-data-loss && pnpm build",
  "installCommand": "pnpm install",
  "outputDirectory": ".next",
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ],
  "crons": [
    { "path": "/api/agent/brief", "schedule": "0 5 * * *" },
    { "path": "/api/agent/anomaly", "schedule": "0 * * * *" },
    { "path": "/api/agent/digest", "schedule": "0 6 * * 1" }
  ]
}
