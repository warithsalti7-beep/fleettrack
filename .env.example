# ── Required ─────────────────────────────────────────────────────────
# Postgres connection string (Neon, Supabase, local). Prisma uses this.
DATABASE_URL="postgres://user:pass@host/db"

# HMAC secret for signing the ft_session httpOnly cookie. Rotate to
# invalidate every live session. MUST be >= 32 random bytes in prod.
AUTH_SECRET="change-me-in-prod-use-openssl-rand-base64-32"

# ── Admin-gated operations ───────────────────────────────────────────
# Token used by /api/seed, /api/import/*, and /api/auth/bootstrap as a
# pre-session bearer. Treat like a password. Pass as `X-Admin-Token`
# header or `?token=` query string.
SEED_TOKEN="change-me-in-prod"

# ── Optional integrations (soft-probed at runtime) ───────────────────
# AI recommendations + summaries. Omit to disable /api/ai/fleet-summary.
ANTHROPIC_API_KEY=""
# (Reserved — not yet used) OpenAI fallback / embeddings.
OPENAI_API_KEY=""
# Transactional email. Omit to disable notifications.
RESEND_API_KEY=""
# Server-side error reporting. Omit to disable.
SENTRY_DSN=""
