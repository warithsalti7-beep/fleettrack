# Database — required
DATABASE_URL="file:./dev.db"

# Session signing (HMAC-SHA256). Any random 32+ char string.
AUTH_SECRET="replace-me-with-a-long-random-string"

# AI — required for /api/ai/* and the agent cron jobs
ANTHROPIC_API_KEY=""

# Telegram bot — see src/app/api/telegram/webhook/route.ts for setup steps
TELEGRAM_BOT_TOKEN=""
# Random string echoed in x-telegram-bot-api-secret-token; pass the same
# value to Telegram's setWebhook call.
TELEGRAM_WEBHOOK_SECRET=""
# Comma-separated Telegram chat ids allowed to use the bot. Get your own
# id by messaging the bot and running /whoami (or via @userinfobot).
TELEGRAM_ADMIN_CHAT_IDS=""

# Bearer token for manually triggering /api/agent/*. Vercel Cron uses
# its own x-vercel-cron header instead and does NOT need this value.
AGENT_SECRET=""

# Optional
OPENAI_API_KEY=""
RESEND_API_KEY=""
SENTRY_DSN=""
SEED_TOKEN=""

# next-auth compat (present for the demo auth flow)
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"
