generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      String   @default("DISPATCHER")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Driver {
  id            String          @id @default(cuid())
  name          String
  email         String          @unique
  phone         String
  licenseNumber String          @unique
  licenseExpiry DateTime
  status        String          @default("AVAILABLE")
  rating        Float           @default(5.0)
  totalTrips    Int             @default(0)
  joinedAt      DateTime        @default(now())
  photoUrl      String?
  address       String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  trips         Trip[]
  vehicles      DriverVehicle[]
  shifts        Shift[]
}

model Vehicle {
  id                   String          @id @default(cuid())
  carId                String?         @unique   // Internal fleet tag e.g. TR2518
  plateNumber          String          @unique
  make                 String
  model                String
  year                 Int
  color                String
  status               String          @default("AVAILABLE")
  fuelType             String          @default("PETROL")
  fuelLevel            Float           @default(100.0)
  mileage              Int             @default(0)
  purchaseDate         DateTime?
  purchasePriceNok     Int?
  leaseMonthlyNok      Int?
  insuranceMonthlyNok  Int?
  lastService          DateTime?
  nextService          DateTime?
  latitude             Float?
  longitude            Float?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  trips                Trip[]
  drivers              DriverVehicle[]
  maintenance          Maintenance[]
  fuelLogs             FuelLog[]
  shifts               Shift[]
  fixedCosts           FixedCost[]
}

model Shift {
  id              String   @id @default(cuid())
  driverId        String
  vehicleId       String
  shiftDate       DateTime
  startTime       String   // "HH:MM"
  endTime         String   // "HH:MM"
  hoursOnline     Float?
  zone            String?
  platformPrimary String?
  status          String   @default("completed")
  createdAt       DateTime @default(now())
  driver          Driver   @relation(fields: [driverId], references: [id])
  vehicle         Vehicle  @relation(fields: [vehicleId], references: [id])

  @@index([shiftDate, driverId])
}

model DriverVehicle {
  id         String   @id @default(cuid())
  driverId   String
  vehicleId  String
  assignedAt DateTime @default(now())
  driver     Driver   @relation(fields: [driverId], references: [id])
  vehicle    Vehicle  @relation(fields: [vehicleId], references: [id])
}

model Trip {
  id             String    @id @default(cuid())
  driverId       String
  vehicleId      String
  status         String    @default("PENDING")
  pickupAddress  String
  dropoffAddress String
  pickupLat      Float?
  pickupLng      Float?
  dropoffLat     Float?
  dropoffLng     Float?
  distance       Float?
  duration       Int?
  fare           Float?
  paymentMethod  String    @default("CASH")
  startedAt      DateTime?
  completedAt    DateTime?
  rating         Float?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  driver         Driver    @relation(fields: [driverId], references: [id])
  vehicle        Vehicle   @relation(fields: [vehicleId], references: [id])
}

model Maintenance {
  id             String    @id @default(cuid())
  vehicleId      String
  type           String
  description    String
  status         String    @default("SCHEDULED")
  priority       String    @default("NORMAL")
  cost           Float?
  scheduledAt    DateTime
  completedAt    DateTime?
  technicianName String?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  vehicle        Vehicle   @relation(fields: [vehicleId], references: [id])
}

model FuelLog {
  id            String   @id @default(cuid())
  vehicleId     String
  liters        Float
  pricePerLiter Float
  totalCost     Float
  mileageAtFill Int
  station       String?
  filledAt      DateTime @default(now())
  createdAt     DateTime @default(now())
  vehicle       Vehicle  @relation(fields: [vehicleId], references: [id])
}

/// Recurring / one-off non-trip costs that feed the P&L.
/// Examples per vehicle: lease, insurance (CASCO, third-party), financing,
/// parking, car wash, platform partner subscription, løyve (taxi licence),
/// taximeter calibration, registration fees, depreciation.
/// Examples fleet-wide (vehicleId=null): office rent, dispatch software,
/// admin salaries, employer NI (arbeidsgiveravgift), accounting.
model FixedCost {
  id          String    @id @default(cuid())
  vehicleId   String?   // null = fleet-wide
  category    String    // LEASE | INSURANCE | FINANCING | PARKING | WASH | LOYVE | TAXIMETER | REGISTRATION | DEPRECIATION | OFFICE | SOFTWARE | SALARY | EMPLOYER_NI | ACCOUNTING | OTHER
  description String
  amountNok   Float     // negative for expense, positive for rebate/refund
  frequency   String    @default("MONTHLY") // ONCE | MONTHLY | QUARTERLY | YEARLY
  startDate   DateTime
  endDate     DateTime?
  vendor      String?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  vehicle     Vehicle?  @relation(fields: [vehicleId], references: [id])

  @@index([category, startDate])
  @@index([vehicleId])
}

/// Append-only audit log of admin actions (import runs, permission
/// changes, role reassignments, manual data edits). Lets us trace
/// every state change back to the user who made it.
model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?  // User.id of the person doing it
  actorEmail String?
  action    String   // e.g. "import.drivers", "perms.grant", "role.change"
  target    String?  // e.g. "driver:drv-123" or "vehicle:TR2518"
  meta      Json?
  ok        Boolean  @default(true)
  ip        String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([actorId])
}
