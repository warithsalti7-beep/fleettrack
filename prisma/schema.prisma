generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      String   @default("DISPATCHER")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// A driver in the fleet. Every revenue-generating person is modelled here,
/// whether they're employed (PAYE), a sole-prop (ENK), or an AS company.
/// Employees + office/mechanic staff live in `Employee` instead.
model Driver {
  id             String          @id @default(cuid())
  name           String
  email          String          @unique
  phone          String
  address        String?
  // Platform-native driver code when the owner/dispatcher has one
  // (e.g. Bolt partner driver id, Uber driver uuid, taxi meter pairing
  // id). Lets trip imports match to the right Driver row without
  // relying on fuzzy name matching.
  externalDriverCode String?  @unique
  // How the fleet engaged the driver contractually. ENK / AS / EMPLOYEE
  // is kept in `employmentType` below; contractType adds the commercial
  // angle. FULL_TIME | PART_TIME | CASUAL | TRIAL | null.
  contractType       String?
  // How payouts are made. WEEKLY_SWEEP | MONTHLY_INVOICE | SAME_DAY | null.
  payoutScheme       String?
  // AM | PM | NIGHT | FLEX — redundant with Shift.startTime but fast
  // for filters on the roster page.
  shiftType          String?
  // Norwegian personal / D-number (fødselsnummer or D-nummer), 11 digits.
  // Stored server-side only; never expose to client without auth scope.
  personalNumber String?         @unique
  licenseNumber  String          @unique
  licenseExpiry  DateTime
  // Bank details for payouts (commission, expense reimbursement).
  bankAccount    String?
  bankName       String?
  // Commission split that the driver keeps of net trip revenue (0..1).
  // Fleet keeps (1 - commissionPct) before tax.
  commissionPct  Float           @default(0.5)
  // How the driver is engaged for tax/accounting purposes.
  // EMPLOYEE = PAYE, employer pays arbeidsgiveravgift + forskuddstrekk
  // ENK      = enkeltpersonforetak (self-employed, driver invoices fleet)
  // AS       = aksjeselskap (driver's company invoices fleet)
  employmentType String          @default("EMPLOYEE") // EMPLOYEE | ENK | AS
  // Org number for ENK / AS drivers (9 digits). Null for employees.
  orgNumber      String?
  // VAT / MVA registered (only ENK/AS above 50k NOK turnover).
  vatRegistered  Boolean         @default(false)
  status         String          @default("AVAILABLE")
  rating         Float           @default(5.0)
  totalTrips     Int             @default(0)
  joinedAt       DateTime        @default(now())
  photoUrl       String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  trips          Trip[]
  vehicles       DriverVehicle[]
  shifts         Shift[]
  documents      DriverDocument[]
  extraKm        ExtraKm[]
  parkingTickets ParkingTicket[]
  repairsAtFault Repair[]         @relation("RepairDriverAtFault")
}

/// Uploaded ID / licence / passport scans for a driver.
/// Each row is one side of one document (front/back for license/id).
model DriverDocument {
  id          String   @id @default(cuid())
  driverId    String
  // LICENSE | PASSPORT | ID_CARD | RESIDENCE_PERMIT | WORK_CONTRACT | OTHER
  type        String
  // FRONT | BACK | SINGLE  (passports are single, license/id have both sides)
  side        String   @default("SINGLE")
  // Blob URL — S3 / R2 / local /public/uploads. Signed URL for private access.
  fileUrl     String
  fileName    String?
  mimeType    String?
  sizeBytes   Int?
  // Document number (licence #, passport #, national id #).
  number      String?
  issuedAt    DateTime?
  expiresAt   DateTime?
  // Country ISO-2 (NO, SE, PL, ...).
  country     String?
  verifiedAt  DateTime?
  verifiedBy  String?   // User.id of the reviewer
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  driver      Driver    @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@index([driverId, type])
  @@index([expiresAt])
}

model Vehicle {
  id                    String          @id @default(cuid())
  carId                 String?         @unique   // Internal fleet tag e.g. TR2518
  plateNumber           String          @unique
  // Uppercase, whitespace-stripped, hyphen-stripped copy of the plate
  // used for fuzzy matching in CSV imports. Written by
  // src/lib/matching.ts#normalizePlate() on every create/update.
  plateNormalized       String?         @unique
  vin                   String?         @unique
  // OWNED | LEASED | FINANCED | DRIVER_OWNED
  ownershipType         String?
  taxiLicenseExpiry     DateTime?
  make                  String
  model                 String
  year                  Int
  color                 String
  status                String          @default("AVAILABLE")
  fuelType              String          @default("PETROL") // PETROL | DIESEL | EV_TESLA | EV_NIO | EV_OTHER | HYBRID
  fuelLevel             Float           @default(100.0)
  mileage               Int             @default(0)
  purchaseDate          DateTime?
  purchasePriceNok      Int?
  leaseMonthlyNok       Int?
  insuranceMonthlyNok   Int?
  // Insurance policy reference + its renewal date (separate from monthly cost).
  insuranceProvider     String?
  insurancePolicyNumber String?
  insuranceExpiry       DateTime?
  // Norwegian periodic vehicle inspection ("EU-kontroll" / PKK), every 2 yrs.
  euKontrollLast        DateTime?
  euKontrollNext        DateTime?
  // Currently mounted tyre set. Switched twice a year by Norwegian law
  // (winter: Nov 1 – Mon after Easter for South / Oct 16 – Apr 30 for North).
  tyreSeason            String?         // WINTER | SUMMER | ALL_SEASON
  tyreChangedAt         DateTime?
  // Straight-line depreciation inputs (Norwegian accounting, saldogruppe c
  // for cars: 24% declining balance; we also store an override for IFRS /
  // management reporting if needed).
  depreciationMethod    String          @default("DECLINING_24") // DECLINING_24 | STRAIGHT_LINE
  depreciationYears     Int?            // for STRAIGHT_LINE
  residualValueNok      Int?
  lastService           DateTime?
  nextService           DateTime?
  latitude              Float?
  longitude             Float?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  trips                 Trip[]
  drivers               DriverVehicle[]
  maintenance           Maintenance[]
  fuelLogs              FuelLog[]
  shifts                Shift[]
  fixedCosts            FixedCost[]
  washEvents            WashEvent[]
  chargingSessions      ChargingSession[]
  batterySwaps          BatterySwap[]
  extraKm               ExtraKm[]
  parkingTickets        ParkingTicket[]
  repairs               Repair[]
  depreciationEntries   DepreciationEntry[]
  taxEntries            TaxEntry[]

  @@index([insuranceExpiry])
  @@index([euKontrollNext])
}

model Shift {
  id              String   @id @default(cuid())
  driverId        String
  vehicleId       String
  shiftDate       DateTime
  startTime       String   // "HH:MM" — scheduled window start
  endTime         String   // "HH:MM" — scheduled window end
  // Actual clock-in / clock-out timestamps. Nullable so the row can be
  // created the night before and filled in as the shift happens. The
  // delta between `clockInAt` and scheduled `startTime` is the
  // punctuality signal used by the driver scorecard.
  clockInAt       DateTime?
  clockOutAt      DateTime?
  // First real trip of the shift — proves the driver was actually
  // working, not just clocked in. Populated by the import pipeline
  // when it first sees a trip whose `startedAt` falls inside this shift.
  firstTripAt     DateTime?
  hoursOnline     Float?
  zone            String?
  platformPrimary String?
  status          String   @default("completed")
  // Where the shift row came from. APP = driver tapped Start/Stop in
  // the portal (live). MANUAL = dispatcher created it by hand.
  // IMPORT = loaded from a bulk CSV. SYSTEM = inferred from trip data.
  // Affects merge priority: a live APP shift wins over a later IMPORT
  // row for the same (driverId, shiftDate, startTime).
  source          String   @default("IMPORT")
  createdAt       DateTime @default(now())
  driver          Driver   @relation(fields: [driverId], references: [id])
  vehicle         Vehicle  @relation(fields: [vehicleId], references: [id])

  @@index([shiftDate, driverId])
  @@index([clockInAt])
  @@index([driverId, status])
}

model DriverVehicle {
  id         String   @id @default(cuid())
  driverId   String
  vehicleId  String
  assignedAt DateTime @default(now())
  driver     Driver   @relation(fields: [driverId], references: [id])
  vehicle    Vehicle  @relation(fields: [vehicleId], references: [id])
}

model Trip {
  id             String    @id @default(cuid())
  driverId       String
  vehicleId      String
  status         String    @default("PENDING")
  // Platform that originated the trip, for idempotent imports.
  // BOLT | UBER | YANGO | NORGESTAXI | DISPATCH | MANUAL
  externalPlatform String?
  // Platform-native trip id (e.g. Bolt order number). Combined with
  // externalPlatform it makes re-uploading the same CSV a no-op.
  externalId     String?
  pickupAddress  String
  dropoffAddress String
  pickupLat      Float?
  pickupLng      Float?
  dropoffLat     Float?
  dropoffLng     Float?
  distance       Float?
  duration       Int?
  // DEPRECATED legacy single-number fare kept for compatibility.
  // New trips populate TripCharge rows instead; `fare` is then the
  // sum of all charges — cached for quick queries.
  fare           Float?
  paymentMethod  String    @default("CASH")
  startedAt      DateTime?
  completedAt    DateTime?
  rating         Float?
  // Free-text cancellation reason when status=CANCELLED. One of:
  // DRIVER_DECLINED | DRIVER_NO_SHOW | RIDER_CANCELLED | PLATFORM_CANCELLED
  cancelReason   String?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  driver         Driver    @relation(fields: [driverId], references: [id])
  vehicle        Vehicle   @relation(fields: [vehicleId], references: [id])
  charges        TripCharge[]

  @@unique([externalPlatform, externalId])
  @@index([status, completedAt])
  @@index([driverId, completedAt])
  @@index([vehicleId, completedAt])
}

/// Line-item breakdown of a Trip's total fare. Lets the dashboard
/// answer "what % of revenue is surge?" or "which driver gets the most
/// tips?" without hacky fare math. Sum of `amountNok` where
/// kind ∈ {BASE, DISTANCE, TIME, SURGE, TOLL, TIP} = gross to driver;
/// kind = PLATFORM_FEE is negative and nets out to payout-base.
model TripCharge {
  id        String  @id @default(cuid())
  tripId    String
  kind      String  // BASE | DISTANCE | TIME | SURGE | TOLL | TIP | PLATFORM_FEE | DISCOUNT
  amountNok Float
  trip      Trip    @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
}

model Maintenance {
  id             String    @id @default(cuid())
  vehicleId      String
  type           String
  description    String
  status         String    @default("SCHEDULED")
  priority       String    @default("NORMAL")
  cost           Float?
  scheduledAt    DateTime
  completedAt    DateTime?
  technicianName String?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  vehicle        Vehicle   @relation(fields: [vehicleId], references: [id])
}

model FuelLog {
  id            String   @id @default(cuid())
  vehicleId     String
  liters        Float
  pricePerLiter Float
  totalCost     Float
  mileageAtFill Int
  station       String?
  filledAt      DateTime @default(now())
  // Idempotency: source = MANUAL | CIRCLEK_CSV | SHELL_CSV | YX_CSV | API
  source        String   @default("MANUAL")
  externalId    String?
  createdAt     DateTime @default(now())
  vehicle       Vehicle  @relation(fields: [vehicleId], references: [id])

  @@unique([source, externalId])
  @@index([vehicleId, filledAt])
}

/// Recurring / one-off non-trip costs that feed the P&L.
/// Examples per vehicle: lease, insurance (CASCO, third-party), financing,
/// parking, car wash, platform partner subscription, løyve (taxi licence),
/// taximeter calibration, registration fees, depreciation.
/// Examples fleet-wide (vehicleId=null): office rent, dispatch software,
/// admin salaries, employer NI (arbeidsgiveravgift), accounting.
model FixedCost {
  id          String    @id @default(cuid())
  vehicleId   String?   // null = fleet-wide
  category    String    // LEASE | INSURANCE | FINANCING | PARKING | WASH | LOYVE | TAXIMETER | REGISTRATION | DEPRECIATION | OFFICE | SOFTWARE | SALARY | EMPLOYER_NI | ACCOUNTING | OTHER
  description String
  amountNok   Float     // negative for expense, positive for rebate/refund
  frequency   String    @default("MONTHLY") // ONCE | MONTHLY | QUARTERLY | YEARLY
  startDate   DateTime
  endDate     DateTime?
  vendor      String?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  vehicle     Vehicle?  @relation(fields: [vehicleId], references: [id])

  @@index([category, startDate])
  @@index([vehicleId])
}

/// Car wash event. Logged every time the car is washed (in-house bay,
/// external car wash, drive-through). Cost is per-event and charged
/// against the vehicle's P&L.
model WashEvent {
  id        String   @id @default(cuid())
  vehicleId String
  washedAt  DateTime @default(now())
  // INTERIOR | EXTERIOR | FULL | DRIVE_THROUGH
  type      String   @default("FULL")
  costNok   Float
  vendor    String?
  // Who washed it — driver or an external vendor.
  washedBy  String?
  notes     String?
  createdAt DateTime @default(now())
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId, washedAt])
}

/// EV charging session. One row per plug-in event. The fleet bills the
/// driver (or absorbs as cost) at a fixed rate (default 3 NOK/kWh).
/// Data can come from:
///   - Tesla Fleet API (vehicle_data -> charge_state)
///   - NIO Power / Smartcar /battery endpoint
///   - Manual entry from receipt
model ChargingSession {
  id             String   @id @default(cuid())
  vehicleId      String
  startedAt      DateTime
  endedAt        DateTime?
  // Energy delivered in kWh (from API or receipt).
  kwh            Float
  // Fleet's internal rate at time of session. Default 3 NOK/kWh.
  ratePerKwhNok  Float    @default(3.0)
  // Computed: kwh * ratePerKwhNok. Stored for historical accuracy.
  totalCostNok   Float
  // HOME | SUPERCHARGER | PUBLIC_AC | PUBLIC_DC | WORKPLACE
  locationType   String?
  location       String?
  latitude       Float?
  longitude      Float?
  // Source of the data — lets us dedupe / know what can be trusted.
  source         String   @default("MANUAL") // MANUAL | TESLA_API | NIO_API | SMARTCAR | CSV
  externalId     String?  // API session id for idempotency
  createdAt      DateTime @default(now())
  vehicle        Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@unique([source, externalId])
  @@index([vehicleId, startedAt])
}

/// NIO Power Swap event. Only applicable to NIO vehicles (ET5, ET7, ES6…).
/// A swap takes ~3-5 minutes and replaces the whole battery pack.
/// Price varies by subscription tier; we log the actual paid amount.
model BatterySwap {
  id            String   @id @default(cuid())
  vehicleId     String
  swappedAt     DateTime @default(now())
  stationId     String?
  stationName   String?
  // Pack capacity after swap (kWh) — NIO offers 75 / 100 / 150 kWh packs.
  packKwh       Float?
  // Price paid for this swap (net of subscription credits).
  costNok       Float
  source        String   @default("MANUAL") // MANUAL | NIO_API
  externalId    String?
  createdAt     DateTime @default(now())
  vehicle       Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@unique([source, externalId])
  @@index([vehicleId, swappedAt])
}

/// Kilometers driven that are NOT part of billed trips — e.g. deadhead,
/// personal use, relocation, waiting-zone repositioning. Sourced from
/// vehicle odometer (Samsara / Tesla / Smartcar) reconciled against
/// the sum of Trip.distance for the period, or from platform exports.
///
/// Taxi platforms without APIs (e.g. Norgestaxi) provide daily CSVs —
/// the importer writes rows here tagged with source=CSV_TAXI.
model ExtraKm {
  id         String   @id @default(cuid())
  vehicleId  String
  driverId   String?
  day        DateTime // truncated to midnight local time
  km         Float
  // BOLT | UBER | YANGO | CSV_TAXI | ODOMETER_DELTA | MANUAL
  source     String   @default("MANUAL")
  externalId String?
  notes      String?
  createdAt  DateTime @default(now())
  vehicle    Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  driver     Driver?  @relation(fields: [driverId], references: [id])

  @@unique([source, externalId])
  @@index([vehicleId, day])
  @@index([driverId, day])
}

/// Parking violation / toll fine issued against a vehicle. Initially the
/// fleet pays; if the driver was at fault we recharge them (tracked via
/// `chargedBackToDriverId`).
model ParkingTicket {
  id                    String   @id @default(cuid())
  vehicleId             String
  issuedAt              DateTime
  issuer                String?  // Municipality / Q-Park / Aimo Park …
  ticketNumber          String?  @unique
  location              String?
  reason                String?
  amountNok             Float
  dueDate               DateTime?
  paid                  Boolean  @default(false)
  paidAt                DateTime?
  // Driver assigned as responsible (if any). If null, fleet absorbs the cost.
  chargedBackToDriverId String?
  chargedBackAmountNok  Float?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  vehicle               Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  driver                Driver?  @relation(fields: [chargedBackToDriverId], references: [id])

  @@index([vehicleId, issuedAt])
}

/// Repair / body-shop / operational fix for a vehicle. Distinct from
/// scheduled `Maintenance` — repairs are incident-driven (collision,
/// breakdown, vandalism, tyre blowout). Fault attribution drives who
/// pays: driver, another insurer, fleet, or manufacturer warranty.
model Repair {
  id              String   @id @default(cuid())
  vehicleId       String
  occurredAt      DateTime
  reportedAt      DateTime @default(now())
  completedAt     DateTime?
  // COLLISION | BODY | MECHANICAL | TYRE | GLASS | ELECTRICAL | VANDALISM | OTHER
  category        String
  description     String
  // Workshop / vendor performing the repair.
  vendor          String?
  costNok         Float
  // Whose fault, for cost allocation. FLEET = we eat it.
  faultCategory   String   @default("FLEET") // DRIVER | OTHER_INSURANCE | FLEET | MANUFACTURER | UNKNOWN
  faultDriverId   String?
  insuranceClaim  String?  // claim # if recovered via insurance
  deductibleNok   Float?   // "egenandel" — what the fleet still pays
  status          String   @default("OPEN") // OPEN | IN_PROGRESS | DONE | WRITTEN_OFF
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  vehicle         Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  faultDriver     Driver?  @relation("RepairDriverAtFault", fields: [faultDriverId], references: [id])

  @@index([vehicleId, occurredAt])
  @@index([faultDriverId])
}

/// Monthly depreciation accounting entry. Populated by a scheduled job
/// at month-close based on the Vehicle's `depreciationMethod`,
/// `purchasePriceNok`, and remaining book value.
///
/// Norway: cars are saldogruppe c → 24% declining balance per year
/// (i.e. ~2% per month on opening book value). We also accept straight-line
/// for management reporting.
model DepreciationEntry {
  id              String   @id @default(cuid())
  vehicleId       String
  periodStart     DateTime // first day of the accounting period
  periodEnd       DateTime // last day (inclusive)
  openingValueNok Float
  amountNok       Float    // depreciation charged this period
  closingValueNok Float
  method          String   // DECLINING_24 | STRAIGHT_LINE
  createdAt       DateTime @default(now())
  vehicle         Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@unique([vehicleId, periodStart])
  @@index([vehicleId, periodStart])
}

/// Tax liability entry generated from revenue events. We compute at
/// multiple granularities (INSTANT per trip, DAILY, WEEKLY, MONTHLY,
/// QUARTERLY, YEARLY) so the database can answer any "taxes as of X"
/// query without recomputing.
///
/// Norwegian context:
///   - MVA (VAT) on taxi rides is currently 12% (low rate).
///   - Fleet-level corporate tax is 22% on profit (selskapsskatt).
///   - For ENK drivers, personal income tax (trinnskatt + trygdeavgift 11%)
///     applies to net income instead.
///   - Employer NI (arbeidsgiveravgift) varies 0–14.1% by region ("sone").
///
/// `kind` tells you which tax: VAT_COLLECTED, VAT_DEDUCTIBLE, CORP_TAX,
/// INCOME_TAX_WITHHELD, EMPLOYER_NI, SELF_EMPLOYED_NI.
model TaxEntry {
  id           String   @id @default(cuid())
  vehicleId    String?
  driverId     String?
  tripId       String?
  // Bucket for rollups.
  granularity  String   // INSTANT | DAILY | WEEKLY | MONTHLY | QUARTERLY | YEARLY
  periodStart  DateTime
  periodEnd    DateTime
  kind         String
  // Gross revenue (or wage) this entry is derived from.
  baseNok      Float
  // Tax rate applied (0.12 for 12% VAT, 0.22 for corp tax, etc.).
  rate         Float
  // Tax amount (baseNok * rate, but stored explicitly for audit).
  amountNok    Float
  // What set of rules generated this. Bumped when legislation changes.
  rulesVersion String   @default("NO-2026")
  createdAt    DateTime @default(now())
  vehicle      Vehicle? @relation(fields: [vehicleId], references: [id])

  @@index([granularity, periodStart])
  @@index([vehicleId, periodStart])
  @@index([driverId, periodStart])
  @@index([tripId])
}

/// Non-driver staff: mechanics, dispatchers, accountants, office admins.
/// Drivers live in `Driver` even if they're PAYE employees — this model
/// is for back-office roles that don't generate trip revenue directly.
model Employee {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  phone          String?
  address        String?
  personalNumber String?  @unique
  // DISPATCHER | ACCOUNTANT | MECHANIC | MANAGER | OFFICE_ADMIN | OTHER
  role           String
  // Link to application user if they have login access.
  userId         String?  @unique
  employmentType String   @default("EMPLOYEE") // EMPLOYEE | CONTRACTOR_ENK | CONTRACTOR_AS
  orgNumber      String?
  // Gross monthly salary (NOK) for employees, or monthly retainer for contractors.
  monthlySalaryNok Float?
  // Employer NI zone — 1..5 by Norwegian region, drives arbeidsgiveravgift rate.
  niZone         Int?
  bankAccount    String?
  bankName       String?
  startDate      DateTime
  endDate        DateTime?
  active         Boolean  @default(true)
  photoUrl       String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([role, active])
}

/// One row per import run. Stores what was uploaded, by whom, how many
/// rows succeeded/failed, the file hash, and a pointer to structured
/// error details. Required for tax / regulatory traceability in Norway.
model ImportLog {
  id            String   @id @default(cuid())
  entity        String   // drivers | vehicles | trips | shifts | fuel_logs | maintenance | fixed_costs | users | extra_km | ...
  actorId       String?  // User.id
  actorEmail    String?
  fileName      String?
  fileHash      String?  // sha256 of the uploaded bytes; catches re-uploads
  sizeBytes     Int?
  rowsTotal     Int      @default(0)
  rowsInserted Int       @default(0)
  rowsUpdated  Int       @default(0)
  rowsSkipped  Int       @default(0)
  rowsFailed   Int       @default(0)
  errors       Json?     // array of { row, field, message }
  status       String    @default("OK") // OK | PARTIAL | FAILED
  durationMs   Int?
  createdAt    DateTime  @default(now())

  @@index([entity, createdAt])
  @@index([actorId])
}

/// Customer-initiated feedback or operational incident. Populated from
/// platform ratings (Bolt/Uber), rider complaints posted through
/// support, and driver-reported incidents (crash, safety concern).
/// Links back to a specific Trip when possible so analytics can tie
/// ratings + disputes to the revenue event they relate to.
model Incident {
  id          String    @id @default(cuid())
  driverId    String?
  vehicleId   String?
  tripId      String?
  occurredAt  DateTime
  // COMPLAINT | LOW_RATING | CRASH | SAFETY_CONCERN | DISPUTE | PROPERTY_DAMAGE
  kind        String
  // 1..5 for LOW_RATING, else LOW | MEDIUM | HIGH
  severity    String
  description String
  reporter    String?   // customer | driver | ops | platform
  status      String    @default("OPEN") // OPEN | IN_REVIEW | RESOLVED | DISMISSED
  resolvedAt  DateTime?
  resolution  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([driverId, occurredAt])
  @@index([vehicleId, occurredAt])
  @@index([status])
}

/// Driving-behaviour event sourced from telematics (Samsara OBD,
/// Smartcar, Tesla API). Feeds the safety side of the driver score.
/// `source + externalId` is unique so re-ingestion is idempotent.
model DriverEvent {
  id          String   @id @default(cuid())
  driverId    String?
  vehicleId   String
  occurredAt  DateTime
  // HARSH_BRAKE | HARSH_ACCEL | SPEEDING | IDLE_OVER | SEATBELT_OFF | PHONE_USE | HARSH_CORNER
  kind        String
  severity    String   // LOW | MEDIUM | HIGH
  latitude    Float?
  longitude   Float?
  speedKph    Float?
  source      String   // SAMSARA | TESLA | NIO | SMARTCAR | MANUAL
  externalId  String?
  createdAt   DateTime @default(now())

  @@unique([source, externalId])
  @@index([driverId, occurredAt])
  @@index([vehicleId, occurredAt])
}

/// Raw telematics sample — GPS + vehicle state. Stored at 10-60 s
/// cadence; at fleet scale this table gets large (150 M rows / year
/// for 500 vehicles at 10 s). Partition by `sampledAt` in production
/// and keep only 90 days hot.
model TelematicsSample {
  id          String   @id @default(cuid())
  vehicleId   String
  source      String   // SAMSARA | TESLA | NIO | SMARTCAR
  sampledAt   DateTime
  latitude    Float
  longitude   Float
  speedKph    Float?
  heading     Float?
  odometerKm  Float?
  batteryPct  Float?   // EVs
  fuelPct     Float?   // ICE
  ignitionOn  Boolean?
  externalId  String?
  createdAt   DateTime @default(now())

  @@unique([source, externalId])
  @@index([vehicleId, sampledAt])
}

/// ────────────────────────────────────────────────────────────────
/// Raw per-source trip staging tables
/// ────────────────────────────────────────────────────────────────
/// The spec requires Uber / Bolt / Taxi imports to stay visibly
/// separate at the ingestion layer. Each uploaded row is parked here
/// *as-is* before being normalised into the shared `Trip` table.
/// Owners can re-run normalisation, inspect the original payload, or
/// roll back a specific batch without touching other sources' data.
///
/// `rawPayload` keeps the original CSV row as JSON so nothing is lost
/// when the normaliser evolves. `normalizedTripId` points to the Trip
/// row that consumed this raw row (null until the normaliser has run
/// on it). `importBatchId` groups all rows that came from one upload
/// so the UI can show "Bolt batch 2026-04-14T08:02 — 312 rows".
model UberRawTrip {
  id                   String   @id @default(cuid())
  importBatchId        String
  fileName             String?
  importedAt           DateTime @default(now())
  rowNumber            Int
  rawPayload           Json
  parseStatus          String   @default("PARSED") // PARSED | FAILED
  normalizationStatus  String   @default("PENDING") // PENDING | NORMALIZED | FAILED | SKIPPED_DUP
  errorMessage         String?
  // Uber-specific parsed-but-still-raw columns that make querying easy
  // without touching the JSON. Populated by the parser when it can.
  uberTripUuid         String?
  driverEmail          String?
  driverName           String?
  vehiclePlate         String?
  tripStartAt          DateTime?
  tripEndAt            DateTime?
  grossFare            Float?
  platformFee          Float?
  driverEarnings       Float?
  tips                 Float?
  tolls                Float?
  distanceKm           Float?
  durationMin          Int?
  pickupAddress        String?
  dropoffAddress       String?
  currency             String?
  normalizedTripId     String?  @unique

  @@unique([uberTripUuid])
  @@index([importBatchId])
  @@index([normalizationStatus])
}

model BoltRawTrip {
  id                   String   @id @default(cuid())
  importBatchId        String
  fileName             String?
  importedAt           DateTime @default(now())
  rowNumber            Int
  rawPayload           Json
  parseStatus          String   @default("PARSED")
  normalizationStatus  String   @default("PENDING")
  errorMessage         String?
  boltOrderId          String?
  driverEmail          String?
  driverName           String?
  vehiclePlate         String?
  tripStartAt          DateTime?
  tripEndAt            DateTime?
  grossFare            Float?
  platformFee          Float?
  driverEarnings       Float?
  tips                 Float?
  tolls                Float?
  distanceKm           Float?
  durationMin          Int?
  pickupAddress        String?
  dropoffAddress       String?
  currency             String?
  cancellationFee      Float?
  normalizedTripId     String?  @unique

  @@unique([boltOrderId])
  @@index([importBatchId])
  @@index([normalizationStatus])
}

/// Covers Norgestaxi / 07000 / dispatch-meter exports. The shape is
/// looser than Uber/Bolt because Norwegian taxi meter dumps vary
/// between makers — we keep `meterReceiptId` as the best dedupe key
/// and the whole row in `rawPayload`.
model TaxiRawTrip {
  id                   String   @id @default(cuid())
  importBatchId        String
  fileName             String?
  importedAt           DateTime @default(now())
  rowNumber            Int
  rawPayload           Json
  parseStatus          String   @default("PARSED")
  normalizationStatus  String   @default("PENDING")
  errorMessage         String?
  meterReceiptId       String?
  driverName           String?
  vehiclePlate         String?
  tripStartAt          DateTime?
  tripEndAt            DateTime?
  grossFare            Float?
  tips                 Float?
  tolls                Float?
  distanceKm           Float?
  durationMin          Int?
  paymentType          String?
  normalizedTripId     String?  @unique

  @@unique([meterReceiptId])
  @@index([importBatchId])
  @@index([normalizationStatus])
}

/// Driver settlement / payout row as it arrived from the source
/// (Bolt weekly sheet, Uber weekly sheet, dispatcher spreadsheet).
/// The normalised Settlement below is what dashboards read.
model SettlementRawRow {
  id             String   @id @default(cuid())
  importBatchId  String
  source         String   // BOLT | UBER | DISPATCHER | MANUAL
  fileName       String?
  importedAt     DateTime @default(now())
  rowNumber      Int
  rawPayload     Json
  parseStatus    String   @default("PARSED")
  errorMessage   String?
  driverEmail    String?
  periodStart    DateTime?
  periodEnd      DateTime?
  grossRevenue   Float?
  platformCommission Float?
  netRevenue     Float?
  bonusTotal     Float?
  deductionsTotal Float?
  payoutTotal    Float?
  vatTotal       Float?
  normalizedSettlementId String?  @unique

  @@index([importBatchId])
  @@index([source, periodStart])
}

/// Normalised settlement — the single source of truth for weekly
/// payouts on driver dashboards. Deduped on (driverId, source,
/// periodStart, periodEnd) so re-importing the same sheet is a no-op.
model Settlement {
  id             String   @id @default(cuid())
  driverId       String
  source         String   // BOLT | UBER | DISPATCHER | MANUAL
  periodStart    DateTime
  periodEnd      DateTime
  grossRevenue   Float
  platformCommission Float  @default(0)
  netRevenue     Float
  bonusTotal     Float    @default(0)
  deductionsTotal Float   @default(0)
  payoutTotal    Float
  vatTotal       Float?
  status         String   @default("FINAL")   // DRAFT | FINAL | PAID | CANCELLED
  importBatchId  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([driverId, source, periodStart, periodEnd])
  @@index([driverId, periodStart])
  @@index([source, periodStart])
}

/// Rows surfaced in the new "Errors & Sync" page. Every nightly
/// diagnostics job writes here; the UI lets a dispatcher mark one
/// RESOLVED / DISMISSED. Idempotent via `fingerprint` so the same
/// issue re-detected on the next run doesn't duplicate.
model DataIssue {
  id          String   @id @default(cuid())
  kind        String   // DUP_TRIP | DUP_DRIVER | DUP_VEHICLE | TRIP_NO_DRIVER |
                       // TRIP_NO_VEHICLE | OPEN_SHIFT_STALE | TRIP_OUTSIDE_SHIFT |
                       // INACTIVE_DRIVER_NEW_TRIP | INACTIVE_VEHICLE_NEW_TRIP |
                       // IMPORT_ROW_FAILED | NEGATIVE_FARE | TOTALS_MISMATCH |
                       // STALE_ACTIVE_DRIVER | PLATE_COLLISION | OTHER
  severity    String   @default("MEDIUM") // LOW | MEDIUM | HIGH | CRITICAL
  entityRef   String?  // "driver:<id>" | "vehicle:<id>" | "trip:<id>" | "shift:<id>"
  batchRef    String?  // ImportLog / raw-table batch id
  details     Json?
  suggestion  String?
  fingerprint String   @unique
  status      String   @default("OPEN") // OPEN | RESOLVED | DISMISSED
  openedAt    DateTime @default(now())
  resolvedAt  DateTime?
  resolvedBy  String?

  @@index([status, severity])
  @@index([kind])
}

/// Append-only audit log of admin actions (import runs, permission
/// changes, role reassignments, manual data edits). Lets us trace
/// every state change back to the user who made it.
model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?  // User.id of the person doing it
  actorEmail String?
  action    String   // e.g. "import.drivers", "perms.grant", "role.change"
  target    String?  // e.g. "driver:drv-123" or "vehicle:TR2518"
  meta      Json?
  ok        Boolean  @default(true)
  ip        String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([actorId])
}
