# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string (required)
DATABASE_URL=postgresql://fleettrack:password@localhost:5432/fleettrack

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# Optional Redis credentials (Upstash, Redis Cloud, etc.)
# REDIS_URL=rediss://user:password@your-redis.upstash.io:6380

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate secure secrets: openssl rand -base64 64
JWT_SECRET=change-me-to-a-64-char-random-string
JWT_REFRESH_SECRET=change-me-to-another-64-char-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Tesla Fleet API ──────────────────────────────────────────────────────────
# Register at: developer.tesla.com
TESLA_CLIENT_ID=
TESLA_CLIENT_SECRET=
TESLA_REDIRECT_URI=http://localhost:3001/api/v1/auth/tesla/callback
TESLA_AUDIENCE=https://fleet-api.prd.na.vn.cloud.tesla.com

# ─── Smartcar (NIO, BMW, Ford, Hyundai, VW, 40+ brands) ──────────────────────
# Register at: dashboard.smartcar.com
SMARTCAR_CLIENT_ID=
SMARTCAR_CLIENT_SECRET=
SMARTCAR_REDIRECT_URI=http://localhost:3001/api/v1/auth/smartcar/callback

# ─── Google Maps Platform ─────────────────────────────────────────────────────
# Enable: Geocoding API, Directions API, Distance Matrix API
GOOGLE_MAPS_API_KEY=

# ─── Samsara Telematics ───────────────────────────────────────────────────────
SAMSARA_API_KEY=

# ─── Sentry (error tracking) ──────────────────────────────────────────────────
SENTRY_DSN=

# ─── Rate limiting ────────────────────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ─── Telematics sync ──────────────────────────────────────────────────────────
# Interval for the sync cron job (seconds)
TELEMATICS_SYNC_INTERVAL_SEC=10
