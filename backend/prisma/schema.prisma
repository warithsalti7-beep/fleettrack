// ─────────────────────────────────────────────────────────────────────────────
// FleetTrack — Production Prisma Schema (PostgreSQL)
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "fullTextIndex"]
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  ADMIN
  DISPATCHER
  DRIVER
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  OFF_DUTY
  SUSPENDED
  PENDING_APPROVAL
}

enum VehicleType {
  SEDAN
  SUV
  VAN
  ELECTRIC
  HYBRID
}

enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  MAINTENANCE
  CHARGING
  OUT_OF_SERVICE
  DECOMMISSIONED
}

enum FuelType {
  PETROL
  DIESEL
  HYBRID
  ELECTRIC
  HYDROGEN
}

enum TelematicsProvider {
  TESLA_FLEET
  SMARTCAR
  SAMSARA
  MANUAL
  SIMULATED
}

enum TripStatus {
  PENDING
  DRIVER_ASSIGNED
  DRIVER_EN_ROUTE
  ARRIVED_PICKUP
  IN_PROGRESS
  COMPLETED
  CANCELLED
  DISPUTED
}

enum PaymentMethod {
  CASH
  CARD
  MOBILE_MONEY
  CORPORATE_ACCOUNT
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  FAILED
}

enum MaintenanceType {
  OIL_CHANGE
  TIRE_ROTATION
  BRAKE_SERVICE
  BATTERY_SERVICE
  GENERAL_INSPECTION
  ANNUAL_INSPECTION
  REPAIR
  RECALL
  CHARGING_SYSTEM
}

enum MaintenanceStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  OVERDUE
}

enum MaintenancePriority {
  LOW
  NORMAL
  HIGH
  URGENT
  CRITICAL
}

// ─── Users (dashboard accounts) ──────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String
  role         UserRole  @default(DISPATCHER)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  refreshTokens RefreshToken[]

  @@index([email])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("refresh_tokens")
}

// ─── Drivers ─────────────────────────────────────────────────────────────────

model Driver {
  id               String       @id @default(cuid())
  name             String
  email            String       @unique
  phone            String
  phoneVerified    Boolean      @default(false)
  licenseNumber    String       @unique
  licenseExpiry    DateTime
  licenseClass     String       @default("B")
  status           DriverStatus @default(AVAILABLE)
  isOnline         Boolean      @default(false)
  lastSeenAt       DateTime?
  rating           Float        @default(5.0)
  ratingCount      Int          @default(0)
  acceptanceRate   Float        @default(100.0)  // % of trip requests accepted
  completionRate   Float        @default(100.0)  // % of accepted trips completed
  totalTrips       Int          @default(0)
  totalDistance    Float        @default(0)      // km
  totalEarnings    Float        @default(0)      // USD
  photoUrl         String?
  address          String?
  emergencyContact String?
  notes            String?
  joinedAt         DateTime     @default(now())
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  deletedAt        DateTime?

  // Last known location (cached here for fast queries; detailed in telematics)
  locationLat Float?
  locationLng Float?
  locationAt  DateTime?

  trips    Trip[]
  vehicles DriverVehicle[]

  @@index([status])
  @@index([isOnline])
  @@index([rating])
  @@map("drivers")
}

// ─── Vehicles (EV-ready) ─────────────────────────────────────────────────────

model Vehicle {
  id          String        @id @default(cuid())
  plateNumber String        @unique
  vin         String?       @unique  // Vehicle Identification Number
  make        String
  model       String
  year        Int
  color       String
  type        VehicleType   @default(SEDAN)
  status      VehicleStatus @default(AVAILABLE)

  // Fuel / Energy
  fuelType     FuelType @default(PETROL)
  fuelLevel    Float    @default(100.0)  // % for ICE, SoC% for EV
  batteryLevel Float?                    // EV: State of Charge 0-100
  batteryRange Float?                    // EV: estimated range in km
  isCharging   Boolean  @default(false)
  chargingPower Float?                   // kW

  // Odometer / Usage
  mileage   Int   @default(0)           // km
  mileageKm Float @default(0)           // same as above, float precision

  // Telematics integration
  telematicsProvider TelematicsProvider @default(MANUAL)
  telematicsVehicleId String?           // External ID (Tesla VIN, Smartcar ID, etc.)
  telematicsEnabled  Boolean @default(false)

  // Last known GPS location
  locationLat Float?
  locationLng Float?
  locationAt  DateTime?
  speedKmh    Float?
  heading     Float?                    // degrees 0-360

  // Service dates
  lastService DateTime?
  nextService DateTime?
  insuranceExpiry DateTime?
  registrationExpiry DateTime?

  // Metadata
  imageUrl  String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  trips           Trip[]
  drivers         DriverVehicle[]
  maintenanceLogs MaintenanceRecord[]
  fuelLogs        FuelLog[]
  telematicsLogs  TelematicsLog[]

  @@index([status])
  @@index([type])
  @@index([telematicsProvider])
  @@index([plateNumber])
  @@map("vehicles")
}

model DriverVehicle {
  id         String   @id @default(cuid())
  driverId   String
  vehicleId  String
  isPrimary  Boolean  @default(true)
  assignedAt DateTime @default(now())
  removedAt  DateTime?

  driver  Driver  @relation(fields: [driverId], references: [id])
  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  @@unique([driverId, vehicleId])
  @@index([driverId])
  @@index([vehicleId])
  @@map("driver_vehicles")
}

// ─── Trips ────────────────────────────────────────────────────────────────────

model Trip {
  id       String     @id @default(cuid())
  driverId String
  vehicleId String
  status   TripStatus @default(PENDING)

  // Route
  pickupAddress  String
  dropoffAddress String
  pickupLat      Float?
  pickupLng      Float?
  dropoffLat     Float?
  dropoffLng     Float?
  routePolyline  String?  // encoded Google Maps polyline
  distanceKm     Float?
  durationMin    Int?

  // Financial
  estimatedFare Float?
  fare          Float?
  tip           Float?    @default(0)
  platformFee   Float?    @default(0)
  driverEarning Float?
  paymentMethod PaymentMethod @default(CASH)
  paymentStatus PaymentStatus @default(PENDING)

  // Timestamps
  scheduledAt  DateTime?
  assignedAt   DateTime?
  enRouteAt    DateTime?
  arrivedAt    DateTime?
  startedAt    DateTime?
  completedAt  DateTime?
  cancelledAt  DateTime?

  // Feedback
  driverRating   Float?
  riderRating    Float?
  driverComment  String?
  riderComment   String?

  // Cancellation
  cancelReason String?
  cancelledBy  String?  // 'driver' | 'rider' | 'system'

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  driver  Driver  @relation(fields: [driverId], references: [id])
  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  @@index([status])
  @@index([driverId])
  @@index([vehicleId])
  @@index([createdAt])
  @@map("trips")
}

// ─── Telematics (time-series GPS + EV data) ───────────────────────────────────

model TelematicsLog {
  id        String   @id @default(cuid())
  vehicleId String
  timestamp DateTime @default(now())

  // GPS
  latitude  Float
  longitude Float
  altitude  Float?
  speedKmh  Float?
  heading   Float?  // 0-360 degrees
  accuracy  Float?  // GPS accuracy in meters

  // EV data
  batteryLevel    Float?  // State of Charge %
  batteryRange    Float?  // Estimated range in km
  isCharging      Boolean @default(false)
  chargingPower   Float?  // kW
  energyAdded     Float?  // kWh added this session

  // ICE data
  fuelLevel Float?  // %

  // Engine / vehicle state
  isOn        Boolean @default(true)
  odometer    Int?    // km
  engineTemp  Float?  // Celsius
  tirePressure Json?  // { fl, fr, rl, rr } in PSI

  // Diagnostics
  obdCodes    String[]  // OBD-II fault codes, e.g. ["P0301"]

  // Source
  provider TelematicsProvider @default(MANUAL)
  rawData  Json?              // Original API response for debugging

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId, timestamp])
  @@index([timestamp])
  @@map("telematics_logs")
}

// ─── Maintenance ──────────────────────────────────────────────────────────────

model MaintenanceRecord {
  id          String              @id @default(cuid())
  vehicleId   String
  type        MaintenanceType
  description String
  status      MaintenanceStatus   @default(SCHEDULED)
  priority    MaintenancePriority @default(NORMAL)
  cost        Float?
  mileageAtService Int?
  scheduledAt DateTime
  startedAt   DateTime?
  completedAt DateTime?
  technicianName String?
  shopName    String?
  invoiceUrl  String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId])
  @@index([status])
  @@index([scheduledAt])
  @@map("maintenance_records")
}

// ─── Fuel / Charging Logs ─────────────────────────────────────────────────────

model FuelLog {
  id            String   @id @default(cuid())
  vehicleId     String
  liters        Float?   // For ICE vehicles
  kWhAdded      Float?   // For EVs
  pricePerUnit  Float    // per liter or per kWh
  totalCost     Float
  mileageAtFill Int
  station       String?
  provider      String?  // e.g. 'Tesla Supercharger', 'Shell', 'BP'
  receiptUrl    String?
  filledAt      DateTime @default(now())
  createdAt     DateTime @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId])
  @@index([filledAt])
  @@map("fuel_logs")
}

// ─── Fleet Settings (singleton config row) ────────────────────────────────────

model FleetSettings {
  /// Singleton row — always use id = "singleton" when upserting
  id        String   @id @default("singleton")
  /// Full FleetConfig JSON object
  config    Json
  updatedAt DateTime @updatedAt
  /// ID of the user who last updated the settings
  updatedBy String?

  @@map("fleet_settings")
}
